MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8787
MCP_HTTP_API_KEY=
DATA_DIR=./data
LOG_LEVEL=INFO

# Browser session mode. Use a visible local browser and reuse this profile.
DOUYIN_BROWSER_PROFILE_DIR=./data/browser-profile
DOUYIN_BROWSER_HEADLESS=false
DOUYIN_BROWSER_AUTO_CLOSE=true
DOUYIN_BROWSER_CHANNEL=chrome
DOUYIN_BROWSER_PAGE_SETTLE_MS=5000
DOUYIN_LIST_CACHE_TTL_HOURS=24
DOUYIN_DETAIL_CACHE_TTL_HOURS=24
DOUYIN_DETAIL_BATCH_SIZE=10
DOUYIN_PROFILE_LOCK_FILENAME=.douyin-mcp.lock
DOUYIN_LIST_PARSER_VERSION=creator-manage-v2
DOUYIN_DETAIL_PARSER_VERSION=creator-detail-v2
DOUYIN_CREATOR_HOME_URL=https://creator.douyin.com/
DOUYIN_CREATOR_VIDEO_URL=https://creator.douyin.com/creator-micro/content/manage
